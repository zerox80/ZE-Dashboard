# ==========================================
# ZE-Dashboard Configuration Example
# Copy this file to .env and adjust values
# ==========================================

# --- SECURITY (CRITICAL) ---
# Secret key used for signing JWT tokens. 
# Generate a secure key using `openssl rand -hex 32` or similar.
SECRET_KEY=

# --- DATABASE ---
# Connection string for the database.
# Default is a local SQLite file mounted in the container.
DATABASE_URL=sqlite:///./data/ze_dashboard.db

# --- BACKEND SETTINGS ---
# Token expiration time in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Initial Admin Password (will be created on first start if user 'admin' doesn't exist)
ADMIN_PASSWORD=

# --- FRONTEND SETTINGS ---
# URL of the backend API. 
# For Docker Nginx setup, '/api' is the correct relative path.
VITE_API_URL=/api

# --- OPERATIONAL SETTINGS ---
RATE_LIMIT_LOGIN=5/minute
PRODUCTION=false
DEBUG_MODE=true
# Comma-separated browser origins allowed to call the API with credentials.
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1,http://127.0.0.1:80

# --- AI FEATURES (Optional) ---
# Mistral AI API Key für automatische PDF-Analyse und Vertrags-Chatbot
# Hol dir einen Key auf https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here
# Resource limits for untrusted PDFs and model context.
MISTRAL_MAX_PDF_PAGES=100
MISTRAL_MAX_OCR_CHARACTERS=100000
MISTRAL_REQUEST_TIMEOUT_SECONDS=120
# AI model defaults used by the backend
MISTRAL_CHAT_MODEL=mistral-medium-3-5
MISTRAL_OCR_MODEL=mistral-ocr-4-0
MISTRAL_OCR_TABLE_FORMAT=markdown
MISTRAL_OCR_INCLUDE_BLOCKS=true
MISTRAL_OCR_CONFIDENCE_GRANULARITY=page
MISTRAL_DOCUMENT_PROCESSING_ENABLED=true
